{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "packageRules": [
    {
      "groupName": "All dependencies",
      "groupSlug": "all",
      "matchUpdateTypes": ["major", "minor", "patch", "pin", "digest"],
      "matchManagers": ["*"],
      "matchDepTypes": ["*"]
    }
  ],
  "prHourlyLimit": 1,
  "prConcurrentLimit": 1
}
