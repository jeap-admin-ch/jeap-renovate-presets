{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "description": "Group all GitHub Actions updates and pin digests",
  "packageRules": [
    {
      "matchManagers": [
        "github-actions"
      ],
      "pinDigests": true,
      "groupName": "All GitHub Actions updates",
      "groupSlug": "github-actions"
    }
  ]
}

